# NeuroSprint backend
NODE_ENV=production

# Use dedicated internal ports so the project can coexist with other apps on the same VPS.
PORT=3211
WS_PORT=3212

# Optional JWT auth for future centralized login.
JWT_SECRET=change-this-secret-before-production

# Allow only your frontend domains.
ALLOWED_ORIGINS=https://нейроспринт.рф,https://www.нейроспринт.рф

# Persistent JSON storage for MVP online competitions.
DATA_FILE=./data/state.json

# Optional Redis for pub/sub and future scaling.
# Docker: redis://neurosprint-redis:6379
# Host install: redis://127.0.0.1:6379
REDIS_URL=redis://neurosprint-redis:6379
