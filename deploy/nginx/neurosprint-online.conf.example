# Replace the server_name values with your exact domain or punycode form from the registrar panel.
# This config is safe for a VPS that already hosts other projects because it only listens for
# the NeuroSprint subdomains and proxies to localhost-only ports 3211/3212.

server {
    listen 80;
    server_name api.REPLACE_WITH_YOUR_DOMAIN;

    location / {
        proxy_pass http://127.0.0.1:3211;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name ws.REPLACE_WITH_YOUR_DOMAIN;

    location / {
        proxy_pass http://127.0.0.1:3212;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
