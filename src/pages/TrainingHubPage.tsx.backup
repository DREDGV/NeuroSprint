  id: string;
  color: string;
  gradient: string;
  bgLight: string;
  icon: ReactNode;
  primarySkill: string;
  secondarySkills: string[];
  timeLabel: string;
  benefit: string;
  bestFor: string;
  routeLabel: string;
  formatLabel: string;
  skillId: SkillId;
}

